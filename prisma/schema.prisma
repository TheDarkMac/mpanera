generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  PROVIDER
}

enum ServiceRequestStatus {
  OPEN
  NEGOTIATING
  ASSIGNED
  CLOSED
  EXPIRED
}

enum NotificationStatus {
  SENT
  VIEWED
  RESPONDED
  IGNORED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REFUSED
  WITHDRAWN
}

enum JobStatus {
  AWAITING_PAYMENT
  PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentMethod {
  MVOLA
  ORANGE_MONEY
  AIRTEL_MONEY
  CARD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum VerificationDocumentType {
  ID_CARD_FRONT
  ID_CARD_BACK
  FACE_PHOTO
  OTHER
}

enum VerificationDocumentStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum UpdateReminderStatus {
  SENT
  CONFIRMED
  EXPIRED
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  phone              String    @unique
  passwordHash       String
  role               UserRole
  onboardingComplete Boolean   @default(false)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  lastLoginAt        DateTime?

  client            Client?
  provider          Provider?
  reviewedDocuments VerificationDocument[] @relation("DocumentReviewer")

  @@map("users")
}

model Client {
  id           String  @id @default(uuid()) @db.Uuid
  userId       String  @unique @db.Uuid
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  district     String?
  city         String?
  neighborhood String?

  serviceRequests ServiceRequest[]
  jobs            Job[]
  payments        Payment[]
  reviews         Review[]

  @@map("clients")
}

model Provider {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName              String
  companyName           String?
  bio                   String?
  district              String?
  city                  String?
  neighborhood          String?
  averageRating         Float     @default(0)
  completedJobsCount    Int       @default(0)
  verified              Boolean   @default(false)
  contactUpdatedAt      DateTime?
  nextContactReminderAt DateTime?
  createdAt             DateTime  @default(now())

  categories            ProviderCategory[]
  notifications         Notification[]
  offers                Offer[]
  jobs                  Job[]
  verificationDocuments VerificationDocument[]
  updateReminders       UpdateReminder[]
  reviews               Review[]

  @@map("providers")
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  parentId String? @db.Uuid
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  name     String
  slug     String  @unique
  icon     String?

  providers       ProviderCategory[]
  serviceRequests ServiceRequest[]

  @@map("categories")
}

model ProviderCategory {
  providerId String   @db.Uuid
  categoryId String   @db.Uuid
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([providerId, categoryId])
  @@map("provider_categories")
}

model ServiceRequest {
  id               String               @id @default(uuid()) @db.Uuid
  clientId         String               @db.Uuid
  client           Client               @relation(fields: [clientId], references: [id])
  categoryId       String               @db.Uuid
  category         Category             @relation(fields: [categoryId], references: [id])
  title            String
  description      String
  district         String?
  indicativeBudget Decimal?
  desiredDeadline  DateTime?
  status           ServiceRequestStatus @default(OPEN)
  createdAt        DateTime             @default(now())
  expiresAt        DateTime?

  photos        ServiceRequestPhoto[]
  notifications Notification[]
  offers        Offer[]
  job           Job?

  @@map("service_requests")
}

model ServiceRequestPhoto {
  id               String         @id @default(uuid()) @db.Uuid
  serviceRequestId String         @db.Uuid
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  fileUrl          String
  order            Int            @default(0)

  @@map("service_request_photos")
}

model Notification {
  id               String             @id @default(uuid()) @db.Uuid
  serviceRequestId String             @db.Uuid
  serviceRequest   ServiceRequest     @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  providerId       String             @db.Uuid
  provider         Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status           NotificationStatus @default(SENT)
  sentAt           DateTime           @default(now())
  viewedAt         DateTime?

  offer Offer?

  @@map("notifications")
}

model Offer {
  id               String         @id @default(uuid()) @db.Uuid
  notificationId   String         @unique @db.Uuid
  notification     Notification   @relation(fields: [notificationId], references: [id])
  serviceRequestId String         @db.Uuid
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  providerId       String         @db.Uuid
  provider         Provider       @relation(fields: [providerId], references: [id])
  proposedPrice    Decimal
  message          String?
  status           OfferStatus    @default(PENDING)
  createdAt        DateTime       @default(now())

  proposedSlots ProposedTimeSlot[]
  acceptedJob   Job?

  @@map("offers")
}

model ProposedTimeSlot {
  id      String   @id @default(uuid()) @db.Uuid
  offerId String   @db.Uuid
  offer   Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  start   DateTime
  end     DateTime

  @@map("proposed_time_slots")
}

model Job {
  id               String         @id @default(uuid()) @db.Uuid
  serviceRequestId String         @unique @db.Uuid
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  clientId         String         @db.Uuid
  client           Client         @relation(fields: [clientId], references: [id])
  providerId       String         @db.Uuid
  provider         Provider       @relation(fields: [providerId], references: [id])
  acceptedOfferId  String         @unique @db.Uuid
  acceptedOffer    Offer          @relation(fields: [acceptedOfferId], references: [id])
  finalPrice       Decimal
  chosenSlotStart  DateTime?
  chosenSlotEnd    DateTime?
  status           JobStatus      @default(AWAITING_PAYMENT)
  createdAt        DateTime       @default(now())
  completedAt      DateTime?

  payment Payment?
  review  Review?

  @@map("jobs")
}

model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  jobId        String        @unique @db.Uuid
  job          Job           @relation(fields: [jobId], references: [id])
  clientId     String        @db.Uuid
  client       Client        @relation(fields: [clientId], references: [id])
  amount       Decimal
  method       PaymentMethod
  apiReference String        @unique
  status       PaymentStatus @default(PENDING)
  rawPayload   String?
  paidAt       DateTime?

  @@map("payments")
}

model VerificationDocument {
  id              String                     @id @default(uuid()) @db.Uuid
  providerId      String                     @db.Uuid
  provider        Provider                   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type            VerificationDocumentType
  fileUrl         String
  autoCheckPass   Boolean                    @default(false)
  autoCheckLog    String?
  status          VerificationDocumentStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?                    @db.Uuid
  reviewedBy      User?                      @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  submittedAt     DateTime                   @default(now())
  reviewedAt      DateTime?

  @@map("verification_documents")
}

model UpdateReminder {
  id          String               @id @default(uuid()) @db.Uuid
  providerId  String               @db.Uuid
  provider    Provider             @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status      UpdateReminderStatus @default(SENT)
  sentAt      DateTime             @default(now())
  confirmedAt DateTime?
  expiresAt   DateTime?

  @@map("update_reminders")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  jobId      String   @unique @db.Uuid
  job        Job      @relation(fields: [jobId], references: [id])
  clientId   String   @db.Uuid
  client     Client   @relation(fields: [clientId], references: [id])
  providerId String   @db.Uuid
  provider   Provider @relation(fields: [providerId], references: [id])
  rating     Int
  comment    String?
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("reviews")
}
